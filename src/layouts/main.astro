---
import "@/styles/global.css"
import MobileNav from "@/components/MobileNav"
import LanguageSwitcher from "@/components/LanguageSwitcher.astro"
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@/i18n/utils"

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const {
  title = t("layout.title"),
  description = t("layout.description"),
} = Astro.props

const links = [
  { href: translatePath("/"), label: t("nav.home") },
  { href: translatePath("/events"), label: t("nav.events") },
  { href: translatePath("/projects"), label: t("nav.projects") },
  { href: translatePath("/blog"), label: t("nav.blog") },
  { href: translatePath("/news"), label: t("nav.news") },
  { href: translatePath("/gallery"), label: t("nav.gallery") },
]
---

<html lang={lang} class="dark snap-y snap-mandatory">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-background text-foreground flex flex-col font-sans antialiased scroll-pt-16">
    <header class="sticky top-0 z-40 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="container mx-auto flex h-16 items-center justify-between px-4 md:px-8">
        <a href={translatePath("/")} class="flex items-center gap-2">
          <img src="/logo.jpg" alt="HEC IA Logo" class="h-8 w-8 rounded-sm object-cover" onerror="this.style.display='none'" />
          <span class="font-bold text-xl tracking-tight text-primary">HEC IA</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-6">
          {links.map(link => (
            <a 
              href={link.href} 
              class="text-sm font-medium text-muted-foreground transition-colors hover:text-primary"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="hidden md:flex items-center gap-4">
          <LanguageSwitcher />
        </div>

        <MobileNav client:load links={links} />
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-border/40 py-6 md:py-0">
      <div class="container mx-auto flex flex-col items-center justify-between gap-4 md:h-24 md:flex-row px-4 md:px-8">
        <p class="text-center text-sm leading-loose text-muted-foreground md:text-left">
          &copy; {new Date().getFullYear()} HEC IA. {t("layout.footer.rights")}
        </p>
        <div class="flex items-center gap-4">
          <a href="https://github.com" target="_blank" rel="noreferrer" class="text-sm font-medium text-muted-foreground hover:text-primary">GitHub</a>
          <a href="https://linkedin.com" target="_blank" rel="noreferrer" class="text-sm font-medium text-muted-foreground hover:text-primary">LinkedIn</a>
        </div>
      </div>
    </footer>
  </body>
</html>
