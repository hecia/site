---
import Layout from "@/layouts/main.astro"
import { Button } from "@/components/ui/button"
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import HeroTitle from "@/components/HeroTitle"
import { getCollection } from "astro:content"

const allEvents = await getCollection("events", ({ data }) => !data.draft)
const upcomingEvents = allEvents
  .filter(e => e.data.startDate > new Date())
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf())
  .slice(0, 3)

const allProjects = await getCollection("projects")
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf())
  .slice(0, 3)

const allBlog = await getCollection("blog", ({ data }) => !data.draft)
const recentBlog = allBlog
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const allNews = await getCollection("news")
const recentNews = allNews
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)

const members = [
  { name: "Magloire Guillet", role: "Co-Président", initials: "MG", image: "/members/magloire-guillet.jpeg",linkedin:"https://www.linkedin.com/in/magloire-t-guillet-64618b177/" },
  { name: "Alexandre Houard", role: "Co-Présidente", initials: "AH", image: "/members/alexandre-houard.jpeg",linkedin:"https://www.linkedin.com/in/alexandre-houard-686960279/" },
  { name: "Alban Poutier", role: "Secrétaire Général", initials: "AP", image: "/members/alban-poutier.jpeg",linkedin:"https://www.linkedin.com/in/alban-hm-poutier/" },
  { name: "Pauline Zmiro", role: "Trésorière", initials: "SB", image: "/members/pauline-zmiro.jpeg",linkedin:"https://www.linkedin.com/in/pauline-zmiro/" },
  { name: "Octave Dumont", role: "Vice-Président : HEC IA Intelligence", initials: "OD", image: "/members/octave-dumont.jpeg",linkedin:"https://www.linkedin.com/in/octave-dumont/" },
]
---

<Layout title="HEC IA - Accueil">
  <!-- Hero -->
  <section class="relative overflow-hidden snap-start min-h-[calc(100dvh)] flex items-center">
    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center space-y-8">
        <HeroTitle client:load />
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed">
          Nous sommes l'association étudiante dédiée à la démocratisation, l'apprentissage et l'application de l'IA dans le monde des affaires.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
          <Button asChild size="lg" className="w-full sm:w-auto rounded-full px-8">
            <a href="/events">Nos Événements</a>
          </Button>
          <Button asChild variant="outline" size="lg" className="w-full sm:w-auto rounded-full px-8">
            <a href="/projects">Découvrir nos Projets</a>
          </Button>
        </div>
      </div>
    </div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-accent-cyan/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
  </section>

  <!-- Le Bureau -->
  <section class="py-16 md:py-24 snap-start" id="bureau">
    <div class="container mx-auto px-4 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight mb-4">Le Bureau</h2>
        <p class="text-muted-foreground max-w-xl mx-auto">Les membres qui font vivre l'association au quotidien.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-8">
        {members.map(member => (
          <a href={member.linkedin}>
          <div class="flex flex-col items-center text-center gap-4">
            <div class="relative group">
              <div class="w-32 h-32 md:w-36 md:h-36 rounded-full bg-primary/10 border-2 border-border overflow-hidden group-hover:border-primary/50 transition-colors">
                <img
                  src={member.image}
                  alt={member.name}
                  class="w-full h-full object-cover"
                  onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                />
                <span class="text-3xl font-bold text-primary w-full h-full items-center justify-center hidden">{member.initials}</span>
              </div>
            </div>
            <div>
              <p class="font-semibold text-base leading-tight">{member.name}</p>
              <p class="text-sm text-muted-foreground mt-1">{member.role}</p>
            </div>
          </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Événements -->
  {upcomingEvents.length > 0 && (
    <section class="py-16 md:py-24 bg-muted/30 snap-start">
      <div class="container mx-auto px-4 md:px-8">
        <div class="flex items-center justify-between mb-10">
          <h2 class="text-3xl font-bold tracking-tight">Événements à venir</h2>
          <a href="/events" class="text-sm font-medium text-primary hover:underline">Voir tout &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {upcomingEvents.map(event => (
            <Card className="flex flex-col h-full border-border/50 bg-background/50 backdrop-blur-sm hover:border-primary/50 transition-colors">
              <CardHeader>
                <div class="flex justify-between items-start gap-4 mb-2">
                  <Badge variant="secondary" className="bg-primary/10 text-primary hover:bg-primary/20">
                    {event.data.startDate.toLocaleDateString('fr-CA', { month: 'short', day: 'numeric' })}
                  </Badge>
                  {event.data.online && <Badge variant="outline">En ligne</Badge>}
                </div>
                <CardTitle className="text-xl line-clamp-2"><a href={`/events/${event.id}`} class="hover:text-primary transition-colors">{event.data.title}</a></CardTitle>
                <CardDescription className="line-clamp-2">{event.data.description}</CardDescription>
              </CardHeader>
              <CardFooter className="mt-auto pt-4 border-t border-border/50 text-sm text-muted-foreground">
                <span class="truncate">{event.data.location}</span>
              </CardFooter>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Projets -->
  {featuredProjects.length > 0 && (
    <section class="py-16 md:py-24 snap-start">
      <div class="container mx-auto px-4 md:px-8">
        <div class="flex items-center justify-between mb-10">
          <h2 class="text-3xl font-bold tracking-tight">Projets en vedette</h2>
          <a href="/projects" class="text-sm font-medium text-primary hover:underline">Voir tout &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map(project => (
            <Card className="flex flex-col h-full border-border/50 hover:border-accent-orange/50 transition-colors">
              <CardHeader>
                <div class="flex justify-between items-start mb-2">
                  <Badge variant={project.data.status === 'active' ? 'default' : 'secondary'}>
                    {project.data.status === 'active' ? 'En cours' : project.data.status === 'completed' ? 'Terminé' : 'Archivé'}
                  </Badge>
                </div>
                <CardTitle className="text-xl line-clamp-2"><a href={`/projects/${project.id}`} class="hover:text-accent-orange transition-colors">{project.data.title}</a></CardTitle>
                <CardDescription className="line-clamp-3">{project.data.description}</CardDescription>
              </CardHeader>
              <CardContent className="mt-auto">
                <div class="flex flex-wrap gap-2">
                  {project.data.technologies.slice(0, 3).map(tech => (
                    <Badge variant="outline" className="text-xs">{tech}</Badge>
                  ))}
                  {project.data.technologies.length > 3 && (
                    <Badge variant="outline" className="text-xs">+{project.data.technologies.length - 3}</Badge>
                  )}
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Blog + News -->
  <section class="py-16 md:py-24 bg-muted/30 snap-start">
    <div class="container mx-auto px-4 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8">
        <div>
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold tracking-tight">Derniers articles</h2>
            <a href="/blog" class="text-sm font-medium text-primary hover:underline">Voir tout &rarr;</a>
          </div>
          <div class="space-y-6">
            {recentBlog.map(post => (
              <div class="group flex flex-col gap-2">
                <p class="text-sm text-muted-foreground">
                  {post.data.pubDate.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                <h3 class="text-lg font-semibold leading-tight group-hover:text-primary transition-colors">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h3>
                <p class="text-sm text-muted-foreground line-clamp-2">{post.data.description}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold tracking-tight">Actualités</h2>
            <a href="/news" class="text-sm font-medium text-primary hover:underline">Voir tout &rarr;</a>
          </div>
          <div class="space-y-6">
            {recentNews.map(item => (
              <div class="group flex flex-col gap-2 border-l-2 border-border pl-4 hover:border-accent-yellow transition-colors">
                <div class="flex items-center gap-2">
                  <Badge variant="outline" className="text-[10px] uppercase tracking-wider">
                    {item.data.category}
                  </Badge>
                  <span class="text-xs text-muted-foreground">
                    {item.data.pubDate.toLocaleDateString('fr-CA', { month: 'short', day: 'numeric' })}
                  </span>
                </div>
                <h3 class="text-base font-medium leading-tight group-hover:text-accent-yellow transition-colors">
                  <a href={`/news/${item.id}`}>{item.data.title}</a>
                </h3>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Réseaux sociaux -->
  <section class="py-16 md:py-24 snap-start">
    <div class="container mx-auto px-4 md:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight mb-4">Rejoignez-nous</h2>
        <p class="text-muted-foreground max-w-xl mx-auto">Suivez nos activités et rejoignez la communauté HEC IA.</p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-6">
        <a href="https://linkedin.com/company/hec-ia" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 px-6 py-3 rounded-full border border-border hover:border-primary/50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          <span class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors">LinkedIn</span>
        </a>
        <a href="https://instagram.com/hec.ia" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 px-6 py-3 rounded-full border border-border hover:border-primary/50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          <span class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors">Instagram</span>
        </a>
        <a href="https://twitter.com/hec_ia" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 px-6 py-3 rounded-full border border-border hover:border-primary/50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          <span class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors">Twitter / X</span>
        </a>
        <a href="https://github.com/hec-ia" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 px-6 py-3 rounded-full border border-border hover:border-primary/50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors">GitHub</span>
        </a>
        <a href="mailto:contact@hec-ia.com" class="group flex items-center gap-3 px-6 py-3 rounded-full border border-border hover:border-primary/50 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground group-hover:text-primary transition-colors"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors">contact@hec-ia.com</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function() {
    var colors = ['#F14703', '#EF1A01', '#398D88'];
    var key = 'hec-ia-accent';
    var color;
    try {
      color = sessionStorage.getItem(key);
      if (!color || colors.indexOf(color) === -1) {
        color = colors[Math.floor(Math.random() * colors.length)];
        sessionStorage.setItem(key, color);
      }
    } catch(e) {
      color = colors[Math.floor(Math.random() * colors.length)];
    }
    document.documentElement.style.setProperty('--primary', color);
  })();
</script>
