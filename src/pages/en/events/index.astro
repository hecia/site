---
import Layout from "@/layouts/main.astro"
import { Card, CardHeader, CardTitle, CardDescription, CardFooter } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { getCollection } from "astro:content"
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
  getDateLocale,
  filterByLocale,
  getSlugFromId,
} from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const allEvents = await getCollection("events", ({ data }) => !data.draft)
const localeEvents = filterByLocale(allEvents, lang)
const now = new Date()

const upcomingEvents = localeEvents
  .filter(e => e.data.startDate > now)
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf())

const pastEvents = localeEvents
  .filter(e => e.data.startDate <= now)
  .sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf())
---

<Layout title={t("events.pageTitle")} description={t("events.description")}>
  <div class="container mx-auto px-4 md:px-8 py-12 md:py-20">
    <div class="max-w-3xl mb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">{t("events.title")}</h1>
      <p class="text-xl text-muted-foreground">
        {t("events.subtitle")}
      </p>
    </div>

    <div class="space-y-16">
      <section>
        <h2 class="text-3xl font-bold tracking-tight mb-8">{t("events.upcoming")}</h2>
        {upcomingEvents.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {upcomingEvents.map(event => (
              <Card className="flex flex-col h-full border-border/50 hover:border-primary/50 transition-colors">
                <CardHeader>
                  <div class="flex justify-between items-start gap-4 mb-2">
                    <Badge variant="secondary" className="bg-primary/10 text-primary hover:bg-primary/20">
                      {event.data.startDate.toLocaleDateString(getDateLocale(lang), { month: 'short', day: 'numeric', year: 'numeric' })}
                    </Badge>
                    {event.data.online && <Badge variant="outline">{t("events.online")}</Badge>}
                  </div>
                  <CardTitle className="text-xl line-clamp-2">
                    <a
                      href={`${translatePath("/events")}/${getSlugFromId(event.id)}`}
                      class="hover:text-primary transition-colors"
                    >
                      {event.data.title}
                    </a>
                  </CardTitle>
                  <CardDescription className="line-clamp-2 mt-2">
                    {event.data.description}
                  </CardDescription>
                </CardHeader>
                <CardFooter className="mt-auto pt-4 border-t border-border/50 text-sm text-muted-foreground">
                  <span class="truncate">{event.data.location}</span>
                </CardFooter>
              </Card>
            ))}
          </div>
        ) : (
          <p class="text-muted-foreground">{t("events.none")}</p>
        )}
      </section>

      {pastEvents.length > 0 && (
        <section>
          <h2 class="text-3xl font-bold tracking-tight mb-8">{t("events.past")}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 opacity-80">
            {pastEvents.map(event => (
              <Card className="flex flex-col h-full border-border/50 bg-muted/20">
                <CardHeader>
                  <div class="flex justify-between items-start gap-4 mb-2">
                    <Badge variant="outline" className="text-muted-foreground">
                      {event.data.startDate.toLocaleDateString(getDateLocale(lang), { month: 'short', day: 'numeric', year: 'numeric' })}
                    </Badge>
                  </div>
                  <CardTitle className="text-xl line-clamp-2">
                    <a
                      href={`${translatePath("/events")}/${getSlugFromId(event.id)}`}
                      class="hover:text-primary transition-colors"
                    >
                      {event.data.title}
                    </a>
                  </CardTitle>
                </CardHeader>
              </Card>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</Layout>
