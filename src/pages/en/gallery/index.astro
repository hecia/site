---
import Layout from "@/layouts/main.astro"
import { Badge } from "@/components/ui/badge"
import { getCollection } from "astro:content"
import {
  getLangFromUrl,
  useTranslations,
  getDateLocale,
  filterByLocale,
  tDynamic,
} from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const allGallery = await getCollection("gallery", ({ data }) => !data.draft)
const sortedGallery = filterByLocale(allGallery, lang).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)

const categories = [...new Set(sortedGallery.map((item) => item.data.category))]
---

<Layout title={t("gallery.pageTitle")} description={t("gallery.description")}>
  <div class="container mx-auto px-4 md:px-8 py-12 md:py-20">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">{t("gallery.title")}</h1>
      <p class="text-lg text-muted-foreground max-w-2xl">
        {t("gallery.subtitle")}
      </p>
      <div class="flex flex-wrap gap-2 mt-6">
        {categories.map(cat => (
          <Badge variant="outline" className="capitalize">{tDynamic(lang, `gallery.category.${cat}`)}</Badge>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedGallery.map(item => (
        <div class="group relative overflow-hidden rounded-xl border border-border/50 bg-card hover:border-primary/50 transition-colors">
          <div class="aspect-[4/3] bg-muted/50 flex items-center justify-center overflow-hidden">
            <img
              src={item.data.image.src}
              alt={item.data.image.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="hidden items-center justify-center w-full h-full absolute inset-0 bg-muted/30">
              <div class="text-center text-muted-foreground p-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 opacity-50"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                <p class="text-xs">{t("gallery.imageToAdd")}</p>
              </div>
            </div>
          </div>
          <div class="p-4">
            <div class="flex items-center gap-2 mb-2">
              <Badge variant="outline" className="text-[10px] uppercase tracking-wider capitalize">{tDynamic(lang, `gallery.category.${item.data.category}`)}</Badge>
              <span class="text-xs text-muted-foreground">
                {item.data.date.toLocaleDateString(getDateLocale(lang), { year: 'numeric', month: 'long' })}
              </span>
            </div>
            <h2 class="font-semibold leading-tight mb-1">{item.data.title}</h2>
            {item.data.description && (
              <p class="text-sm text-muted-foreground line-clamp-2">{item.data.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    {sortedGallery.length === 0 && (
      <div class="text-center py-20 text-muted-foreground">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 opacity-50"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        <p class="text-lg font-medium">{t("gallery.noImages")}</p>
        <p class="text-sm mt-2">{t("gallery.noImagesSub")}</p>
      </div>
    )}
  </div>
</Layout>
